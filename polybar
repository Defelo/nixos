[module/webcam]
type = custom/script
exec = "lsmod | grep -q uvcvideo && echo "ÔÄĹ" || echo %{u#000}%{-u}%{F#999}ÔÄĹ"
click-left = "st -i sudo modprobe $(lsmod | grep -q uvcvideo && echo -r) uvcvideo"
