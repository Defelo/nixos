[module/scratch]
type = custom/script
exec = "cnt=$(i3-msg -t get_tree | grep -o '\"scratchpad_state\":\"fresh\"' | wc -l);[ $cnt = 0 ] && echo %{u#000}%{-u} || echo +${cnt}"
interval=1
format-underline = ${color.acolor}

[module/updates]
type = custom/script
exec = "x=$(pacman -Qu | egrep -v '\[ignored\]$' | wc -l);y=ÔĎ¶;pacman -Quq | grep -q '^(linux|linux-lts)$' && y=ÔÖľ; polybar-msg action updates module_$([[ "$x" = 0 ]] && echo hide || echo show) > /dev/null; echo $y $x"
format-underline = ${color.acolor}
interval=10

[module/restart]
type = custom/script
exec = "polybar-msg action restart module_$([[ -d /usr/lib/modules/$(uname -r) ]] && echo hide || echo show) > /dev/null; echo ÔÄ°"
interval=10

[module/dunst]
type = custom/script
exec = "[ true = $(dunstctl is-paused) ] && echo %{u#000}%{-u}Ôá∂ || echo ÔÉ≥"
interval=1
format-underline = ${color.acolor}
click-left = "dunstctl set-paused toggle"

[module/yk]
type = custom/script
exec = python ~/scripts/yktd.py
tail = true
;format-underline = ${color.acolor}

[module/mem]
type = internal/memory
interval = 2
label = %free%

[module/swap]
type = internal/memory
interval = 2
label = %swap_used%

[module/cpu]
type = internal/cpu
interval = 1
label = %percentage%%
format-underline = ${color.acolor}

[module/battery]
type = internal/battery
full-at = {{polybar.battery.full-at}}
time-format = %H:%M
battery = BAT0
adapter = AC

format-charging = <animation-charging> <label-charging>
label-charging = %percentage%% (%time%)
;label-charging = %percentage%%
format-charging-underline = ${color.acolor}

format-discharging = <ramp-capacity> <label-discharging>
label-discharging = %percentage%% (%time%)
;label-discharging = %percentage%%

format-full = <label-full>
label-full = %percentage%%
format-full-prefix = "ÓÜ§ "

ramp-capacity-0 = ÓÜ§
ramp-capacity-1 = ÓÜ§
ramp-capacity-2 = ÓÜ§
ramp-capacity-3 = ÓÜ§
ramp-capacity-4 = ÓÜ§

ramp-capacity-0-foreground = ${color.red}
ramp-capacity-foreground   = ${color.fg}
bar-capacity-width = 10

animation-charging-0 = "ÓÜ£"
animation-charging-1 = "ÓÜ£"
animation-charging-2 = "ÓÜ£"
animation-charging-3 = "ÓÜ£"
animation-charging-4 = "ÓÜ£"

animation-charging-framerate = 750

{{#if enc}}
